{
  "name": "signage-local-server",
  "version": "1.0.0",
  "main": "index.js",
  "bin": "index.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "data/configs/default.json",
      "bin/**/*",
      "node_modules/ffmpeg-static/ffmpeg.exe"
    ]
  },
  "scripts": {
    "start": "node index.js",
    "ensure:yt-dlp": "node -e \"const {ensureYtDlpBinary}=require('./utils/ytDlp'); ensureYtDlpBinary().then((p)=>{console.log('yt-dlp ready:',p);}).catch((e)=>{console.error(String(e?.message||e)); process.exit(1);});\"",
    "build": "node .\\scripts\\build-version.js build-exe",
    "build:exe": "node .\\scripts\\build-version.js build-exe",
    "build:installer": "powershell -ExecutionPolicy Bypass -File .\\installer\\build-installer.ps1"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
